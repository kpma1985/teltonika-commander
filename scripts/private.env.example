# Teltonika Commander — Announce Bot Credentials
# Copy this file to scripts/announce.env and fill in your values.
# This file is gitignored — never commit announce.env

# One password for all bot accounts
ANNOUNCE_PASSWORD=

# Reddit
REDDIT_EMAIL=reddit@1337.so
REDDIT_USERNAME=teltonika-commander

# Home Assistant Forum (community.home-assistant.io)
HA_FORUM_EMAIL=haforum@1337.so

# administrator.de
ADMIN_DE_EMAIL=adminde@1337.so

# Telematik-Forum.de
TELEMATIK_EMAIL=telematik@1337.so

# IP-Phone-Forum.de
IPPHONE_EMAIL=ipphone@1337.so

