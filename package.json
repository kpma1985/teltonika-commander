{
  "name": "teltonika-sms",
  "private": true,
  "type": "module",
  "workspaces": ["server", "web"],
  "scripts": {
    "setup": "./scripts/setup-env.sh",
    "backup": "./scripts/backup.sh",
    "dev": "./scripts/setup-env.sh --if-missing && bun run --parallel dev:server dev:web",
    "dev:server": "./scripts/setup-env.sh --if-missing && cd server && bun run dev",
    "dev:web": "cd web && bun run dev",
    "build": "cd web && bun run build",
    "build:binary": "./scripts/build-binary.sh",
    "typecheck": "cd server && bun run typecheck && cd ../web && bun run typecheck",
    "publish": "bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "imapflow": "^1.3.2",
    "playwright": "^1.59.1"
  }
}
