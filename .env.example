# Flespi — primary channel (GPRS/Codec-12 commands, device list)
# Create a token at https://flespi.io/panel/#/tokens
FLESPI_TOKEN=
FLESPI_BASE_URL=https://flespi.io

# Sipgate — SMS fallback (optional). Use EITHER OAuth (recommended) OR PAT.
# Leave both empty to disable SMS.
SIPGATE_SMS_ID=s0
SIPGATE_API_BASE_URL=https://api.sipgate.com/v2
SIPGATE_OAUTH_BASE_URL=https://login.sipgate.com/auth/realms/third-party/protocol/openid-connect

# --- Option A: OAuth 2.0 (third-party app) — recommended ---
# Create at https://app.sipgate.com/w0/organization/oauth2
# Register redirect URI: http://localhost:3001/api/sipgate/callback
SIPGATE_CLIENT_ID=
SIPGATE_CLIENT_SECRET=
SIPGATE_REDIRECT_URI=http://localhost:3001/api/sipgate/callback

# --- Option B: Personal Access Token (Basic Auth) — simpler, personal accounts ---
# https://app.sipgate.com/w0/personal-access-token  (scope: sessions:sms:write)
SIPGATE_TOKEN_ID=
SIPGATE_TOKEN=

# Teltonika SMS auth (two-space prefix if login/password not set on device)
TELTONIKA_SMS_LOGIN=
TELTONIKA_SMS_PASSWORD=

# Teltonika Bluetooth Configurator Passwort (leer lassen wenn nicht gesetzt)
BLUETOOTH_PASSWORD=

# Server
PORT=3001
DOCKER_LISTEN_PORT=3001
WEB_DIST_DIR=

# Frontend / dev proxy / public links (Vite, build-time)
VITE_API_PROXY_TARGET=http://localhost:3001
VITE_FLESPI_TOKEN_HELP_URL=https://flespi.com/kb/tokens-access-keys-to-flespi-platform
VITE_SIPGATE_API_CLIENTS_URL=https://app.sipgate.com/api-clients
VITE_SIPGATE_PAT_URL=https://app.sipgate.com/w0/personal-access-token
VITE_OPENSTREETMAP_URL=https://www.openstreetmap.org
VITE_GOOGLE_MAPS_URL=https://www.google.com/maps
